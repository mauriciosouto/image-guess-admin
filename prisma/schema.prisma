generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Puzzle {
  id                  String                @id @default(cuid())
  dataSource          String
  externalCardId      String
  cardName            String
  imageUrl            String
  seed                String
  createdAt           DateTime              @default(now())
  /// Set when the puzzle is ready for play (detail “Save”, or bulk-create for new rows).
  savedAt             DateTime?
  isActive            Boolean               @default(true)
  steps               PuzzleStep[]
  games               games[]
  host_puzzle_history host_puzzle_history[]
  user_card_stats     user_card_stats[]

  @@index([dataSource, externalCardId])
  @@index([dataSource, isActive])
}

model PuzzleStep {
  id          String  @id @default(cuid())
  puzzleId    String
  step        Int
  blur        Float
  brightness  Float
  stepVariant String?
  imageUrl    String?
  puzzle      Puzzle  @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@unique([puzzleId, step])
  @@index([puzzleId, step])
}

model achievements {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String              @unique
  name              String
  description       String
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  user_achievements user_achievements[]
}

model game_players {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id              String        @db.Uuid
  room_player_id       String?       @db.Uuid
  user_id              String?       @db.Uuid
  guest_id             String?
  display_name         String
  avatar_id            String?
  final_rank           Int?
  solved_at_step       Int?
  solved_total_time_ms Int?
  did_win              Boolean       @default(false)
  created_at           DateTime      @default(now()) @db.Timestamptz(6)
  games                games         @relation(fields: [game_id], references: [id], onDelete: Cascade)
  room_players         room_players? @relation(fields: [room_player_id], references: [id])
  users                users?        @relation(fields: [user_id], references: [id])
  guesses              guesses[]

  @@index([game_id])
  @@index([guest_id])
  @@index([user_id])
}

model games {
  id                                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id                            String?        @db.Uuid
  mode                               GameMode
  puzzle_id                          String
  status                             GameStatus
  started_at                         DateTime       @default(now()) @db.Timestamptz(6)
  finished_at                        DateTime?      @db.Timestamptz(6)
  winner_user_id                     String?        @db.Uuid
  winner_guest_id                    String?
  winning_attempt_count              Int?
  winning_total_time_ms              Int?
  created_at                         DateTime       @default(now()) @db.Timestamptz(6)
  game_players                       game_players[]
  Puzzle                             Puzzle         @relation(fields: [puzzle_id], references: [id])
  rooms_games_room_idTorooms         rooms?         @relation("games_room_idTorooms", fields: [room_id], references: [id])
  users                              users?         @relation(fields: [winner_user_id], references: [id])
  guesses                            guesses[]
  rooms_rooms_current_game_idTogames rooms?         @relation("rooms_current_game_idTogames")

  @@index([puzzle_id])
  @@index([room_id])
  @@index([status])
}

model guesses {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id               String       @db.Uuid
  game_player_id        String       @db.Uuid
  step_number           Int
  guess_text            String
  normalized_guess_text String
  is_correct            Boolean
  time_taken_ms         Int
  created_at            DateTime     @default(now()) @db.Timestamptz(6)
  games                 games        @relation(fields: [game_id], references: [id], onDelete: Cascade)
  game_players          game_players @relation(fields: [game_player_id], references: [id], onDelete: Cascade)

  @@index([game_id, game_player_id, step_number])
}

model host_puzzle_history {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  host_user_id   String?  @db.Uuid
  host_guest_id  String?
  puzzle_id      String
  last_played_at DateTime @default(now()) @db.Timestamptz(6)
  users          users?   @relation(fields: [host_user_id], references: [id], onDelete: Cascade)
  Puzzle         Puzzle   @relation(fields: [puzzle_id], references: [id], onDelete: Cascade)

  @@index([host_guest_id, last_played_at])
  @@index([host_user_id, last_played_at])
}

model profiles {
  user_id             String   @id @db.Uuid
  preferred_avatar_id String?
  bio                 String?
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @db.Timestamptz(6)
  users               users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model room_players {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id      String         @db.Uuid
  user_id      String?        @db.Uuid
  guest_id     String?
  display_name String
  avatar_id    String?
  is_host      Boolean        @default(false)
  turn_order   Int?
  joined_at    DateTime       @default(now()) @db.Timestamptz(6)
  left_at      DateTime?      @db.Timestamptz(6)
  is_connected Boolean        @default(true)
  game_players game_players[]
  rooms        rooms          @relation(fields: [room_id], references: [id], onDelete: Cascade)
  users        users?         @relation(fields: [user_id], references: [id])

  @@index([room_id, joined_at])
}

model rooms {
  id                                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  host_user_id                       String?        @db.Uuid
  host_guest_id                      String?
  mode                               GameMode
  state                              RoomState
  selected_sets                      String[]       @default([])
  timer_per_step_seconds             Int?
  current_game_id                    String?        @unique @db.Uuid
  created_at                         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime       @db.Timestamptz(6)
  games_games_room_idTorooms         games[]        @relation("games_room_idTorooms")
  room_players                       room_players[]
  games_rooms_current_game_idTogames games?         @relation("rooms_current_game_idTogames", fields: [current_game_id], references: [id])
  users                              users?         @relation(fields: [host_user_id], references: [id])

  @@index([host_guest_id])
  @@index([host_user_id])
}

model user_achievements {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String       @db.Uuid
  achievement_id String       @db.Uuid
  unlocked_at    DateTime     @default(now()) @db.Timestamptz(6)
  achievements   achievements @relation(fields: [achievement_id], references: [id], onDelete: Cascade)
  users          users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, achievement_id])
}

model user_card_stats {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @db.Uuid
  puzzle_id        String
  times_played     Int      @default(0)
  times_won        Int      @default(0)
  average_attempts Decimal? @db.Decimal(6, 2)
  average_time_ms  Decimal? @db.Decimal(12, 2)
  updated_at       DateTime @db.Timestamptz(6)
  Puzzle           Puzzle   @relation(fields: [puzzle_id], references: [id], onDelete: Cascade)
  users            users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, puzzle_id])
  @@index([user_id])
}

model user_stats {
  user_id                 String   @id @db.Uuid
  games_played            Int      @default(0)
  games_won               Int      @default(0)
  games_lost              Int      @default(0)
  average_attempts_to_win Decimal? @db.Decimal(6, 2)
  best_attempts_record    Int?
  best_time_record_ms     Int?
  updated_at              DateTime @db.Timestamptz(6)
  users                   users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model users {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  display_name        String
  email               String?               @unique
  provider            String?
  avatar_url          String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @db.Timestamptz(6)
  game_players        game_players[]
  games               games[]
  host_puzzle_history host_puzzle_history[]
  profiles            profiles?
  room_players        room_players[]
  rooms               rooms[]
  user_achievements   user_achievements[]
  user_card_stats     user_card_stats[]
  user_stats          user_stats?
}

enum GameMode {
  SINGLE
  COMPETITIVE
  COOP
  CHALLENGE
}

enum GameStatus {
  PENDING
  IN_PROGRESS
  WON
  LOST
  DRAW
  CANCELLED
}

enum RoomState {
  LOBBY
  COUNTDOWN
  IN_PROGRESS
  FINISHED
  ABANDONED
}
